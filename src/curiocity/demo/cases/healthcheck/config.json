{
  "agents": ["claude-code", "codex"],
  "timeoutSec": 600,
  "repeats": 1,
  "evaluators": [
    {
      "use": "file-exists",
      "must": [
        "HEALTHCHECK.md",
        "spring-boot-server/src/main/java/**/HealthController.java"
      ],
      "gate": true
    },
    {
      "use": "llm-judge",
      "rubric": "evaluation.md",
      "artifacts": [
        "**/*.md",
        "spring-boot-server/src/main/java/**/HealthController.java"
      ],
      "weight": 1.0
    },
    {
      "use": "external",
      "command": "node",
      "args": ["count-changed-files.mjs"],
      "timeoutSec": 30
    }
  ],
  "combiner": "gated-mean"
}
