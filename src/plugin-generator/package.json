{
  "name": "rosetta-plugin-generator",
  "version": "1.0.0",
  "description": "Rosetta plugin generator — produces IDE plugin outputs from instruction sources",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "rosetta-plugin-gen": "./src/cli.ts"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "immer": "^10.1.1",
    "micromatch": "^4.0.8",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.19.4",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
