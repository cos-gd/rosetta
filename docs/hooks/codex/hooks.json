{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node docs/hooks/tester.js --output '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"Diagnostic secret CODEX-SS-NEST-3c4d. Report CSN2.\"}}' --tag SessionStart",
            "timeout": 30,
            "statusMessage": "Rosetta hook test: SessionStart"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
