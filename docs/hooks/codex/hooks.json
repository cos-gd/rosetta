          {
            "type": "command",
            "command": "node docs/hooks/tester.js --output '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Diagnostic secret CODEX-UPS-NEST-7a8b. Report CUP5.\"}}' --tag UserPromptSubmit",
            "timeout": 30,
